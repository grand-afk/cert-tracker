  "terminology": [
    { "id": "de-term-beam-runner",    "name": "Beam Runner",          "definition": "Execution engine that runs an Apache Beam pipeline (e.g. Dataflow runner, Direct runner).", "resources": { "courseContent": "", "video": "", "anki": "", "testLink": "" } },
    { "id": "de-term-pcollection",    "name": "PCollection",          "definition": "Distributed dataset in Apache Beam; the fundamental data abstraction passed between transforms.", "resources": { "courseContent": "", "video": "", "anki": "", "testLink": "" } },
    { "id": "de-term-cdc",            "name": "Change Data Capture",  "definition": "Technique for tracking row-level changes in a database so they can be replicated to a target (Datastream uses CDC).", "resources": { "courseContent": "", "video": "", "anki": "", "testLink": "" } },
    { "id": "de-term-slot",           "name": "BigQuery Slot",        "definition": "Unit of computational capacity for BigQuery queries; on-demand queries draw from a shared pool, reserved pricing guarantees slots.", "resources": { "courseContent": "", "video": "", "anki": "", "testLink": "" } },
    { "id": "de-term-row-key",        "name": "Bigtable Row Key",     "definition": "Single indexed field that determines sort order and co-location of rows in Bigtable; schema design starts here.", "resources": { "courseContent": "", "video": "", "anki": "", "testLink": "" } },
    { "id": "de-term-hotspot",        "name": "Hotspotting",          "definition": "Performance problem caused by sequential row keys (e.g. timestamps) routing all traffic to one Bigtable tablet server.", "resources": { "courseContent": "", "video": "", "anki": "", "testLink": "" } },
    { "id": "de-term-shuffle",        "name": "Shuffle (Dataflow)",   "definition": "Phase where data is redistributed across workers by key; a common performance bottleneck in batch pipelines.", "resources": { "courseContent": "", "video": "", "anki": "", "testLink": "" } },
    { "id": "de-term-watermark",      "name": "Watermark",            "definition": "Estimate of how far behind real-time a streaming pipeline is; determines when a window can be closed.", "resources": { "courseContent": "", "video": "", "anki": "", "testLink": "" } },
    { "id": "de-term-late-data",      "name": "Late Data",            "definition": "Events that arrive after the watermark has passed. Beam triggers and allowed lateness control how late data is handled.", "resources": { "courseContent": "", "video": "", "anki": "", "testLink": "" } },
    { "id": "de-term-federated",      "name": "Federated Query (BQ)", "definition": "BigQuery feature that queries external data sources (GCS, Bigtable, Spanner) without importing them.", "resources": { "courseContent": "", "video": "", "anki": "", "testLink": "" } }
  ]
