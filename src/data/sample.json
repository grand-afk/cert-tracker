    { "id": "term-wi", "term": "Workload Identity", "definition": "Links Kubernetes service accounts to Google service accounts, enabling pods to authenticate to GCP without key files.", "courses": ["gke", "iam"], "resources": { "courseContent": "", "video": "", "anki": "", "testLink": "" } },
